# ─────────────────────────────────────────────────────────────────────────────
# Ballerina + Salesforce MCP — one-shot setup config
#
#   1. cp .env.example .env
#   2. Fill in the values below
#   3. npm run setup            (add --no-deploy to stop after build)
#
# This file holds secrets. It is git-ignored. Keep it 0600:  chmod 600 .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Salesforce Connected App (required) ──────────────────────────────────────
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_BASE_URL=https://myorg.my.salesforce.com

# ── Authentication — pick ONE (or leave all blank for browser OAuth) ─────────
# The setup script tries these in order: refresh token → password → browser.
#
# (1) Pre-obtained token (works on any org). Auto-filled after a browser/password run.
SF_REFRESH_TOKEN=
#
# (2) Username + password — password flow auto-obtains the token.
#     Requires: Setup → Identity → OAuth and OpenID Connect Settings →
#               "Allow OAuth Username-Password Flows" = ON.
#     If your org uses a security token, append it to the password (myPassword + ABC123).
#     If this flow is disabled/fails, the script falls back to browser OAuth.
SF_USERNAME=
SF_PASSWORD=
#
# (3) Leave (1) and (2) blank (or run `npm run setup -- --browser`): the script
#     opens your browser, you approve, paste the ?code= back, and it saves the
#     token here automatically. Works on any org — no toggle needed.

# ── Project options (all optional — defaults shown) ──────────────────────────
PROJECT_NAME=salesforce_integration
ORG_NAME=wso2bi
TARGET_OBJECTS=Account,Contact,Lead,Opportunity
PORT=9090
# BI_PATH=~/WSO2Integrator
# SANDBOX=false
# BUILD=true            # set false to skip `bal build` during setup
#
# REST_API=true          # default: generate an HTTP REST API (health + CRUD on PORT).
#                        # Set REST_API=false for a CDC-only project (no HTTP port) —
#                        # this then REQUIRES at least one CDC listener below.

# ── Consumer flow: CDC (Change Data Capture) listeners (optional) ─────────────
# Receive Salesforce change events in your Ballerina service.
# Generates a cdc_<object>.bal file per entry alongside the REST CRUD modules.
#
# CDC_OBJECTS: comma-separated SObject names, or ALL for every CDC-enabled object.
#   Account,Contact      → cdc_account.bal + cdc_contact.bal (/data/AccountChangeEvent etc.)
#   ALL                  → cdc_all_change_events.bal (/data/ChangeEvents)
#   (blank)              → no CDC listeners (setup script will prompt in interactive mode)
# CDC_OBJECTS=Account,Contact
#
# CDC_PLATFORM_EVENTS: comma-separated Platform Event API names (additive with CDC_OBJECTS).
#   Requires the Platform Event to exist and be published in your org.
# CDC_PLATFORM_EVENTS=MyEvent__e
